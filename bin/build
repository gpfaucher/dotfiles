#! /usr/bin/env fish

function link_arch_configs
  set dotfiles_folder ~/dev/projects/dotfiles
  set config_folder ~/.config/
  set usr_source_folder /usr/local/src
  set existing_pwd (pwd)

  cd $dotfiles_folder/arch_linux
  stow -Rt $config_folder config
  sudo stow -Rt $usr_source_folder usr
  cd $existing_pwd
  echo "Linked configuration files succesfully!"

end

switch (uname)
   case Linux
       link_arch_configs
   case Darwin
       echo "Hi Hexly!"
   case '*'
       echo "You're using an unsupported OS. Aborted build process."
end
